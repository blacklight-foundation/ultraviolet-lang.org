{
  "name": "ultraviolet-lang.org",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "docs:spec:generate": "node scripts/generate-spec-docs.mjs",
    "docs:spec:check": "node scripts/check-spec-docs.mjs",
    "docs:links:check": "node scripts/check-doc-links.mjs",
    "build": "npm run docs:spec:check && npm run docs:links:check && astro check && astro build",
    "preview": "astro preview",
    "pages:dev": "npm run build && wrangler pages dev dist"
  },
  "dependencies": {
    "@astrojs/starlight": "^0.39.1",
    "astro": "^6.3.1",
    "katex": "^0.16.45",
    "rehype-katex": "^7.0.1",
    "remark-math": "^6.0.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.2",
    "typescript": "^5.9.3",
    "wrangler": "^4.90.0"
  },
  "overrides": {
    "yaml": "^2.8.3"
  }
}
