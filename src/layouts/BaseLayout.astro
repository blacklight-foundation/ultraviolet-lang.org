---
import '../styles/site.css';
import { oneTimeDonation } from '../data/funding';
import {
  siteDescription,
  siteTitle,
  socialImageAlt,
  socialImageHeight,
  socialImagePath,
  socialImageType,
  socialImageWidth,
} from '../data/siteMetadata.mjs';

interface Props {
  title?: string;
  description?: string;
}

const defaultTitle = siteTitle;
const defaultDescription = siteDescription;

const { title = defaultTitle, description = defaultDescription } = Astro.props;
const pageTitle =
  title === defaultTitle
    ? `${defaultTitle} – A high-visibility language for humans and AI`
    : `${title} | ${defaultTitle}`;
const site = Astro.site ?? new URL('https://ultraviolet-lang.org');
const canonical = new URL(Astro.url.pathname, site).toString();
const socialImage = new URL(socialImagePath, site).toString();

const navLinks = [
  { href: '/docs/', label: 'Docs' },
  { href: '/releases/', label: 'Releases' },
  { href: '/roadmap/', label: 'Roadmap' },
  { href: '/community/', label: 'Community' },
  { href: '/blog/', label: 'Updates' },
  {
    href: 'https://github.com/blacklight-foundation/ultraviolet',
    label: 'GitHub',
  },
];

const footerPrimaryLinks = [
  { href: '/docs/', label: 'Docs' },
  { href: '/releases/', label: 'Releases' },
  { href: '/playground/', label: 'Playground' },
  { href: '/roadmap/', label: 'Roadmap' },
  { href: '/benchmarks/', label: 'Benchmarks' },
  { href: '/community/', label: 'Community' },
  { href: '/blog/', label: 'Updates' },
  { href: '/sponsor/', label: 'Support' },
  {
    href: 'https://github.com/blacklight-foundation/ultraviolet',
    label: 'GitHub',
  },
];

const footerUtilityLinks = [
  { href: '/foundation/', label: 'Foundation' },
  { href: oneTimeDonation.href, label: 'Donate' },
  { href: 'mailto:hello@blacklight.foundation', label: 'Contact' },
  {
    href: 'https://github.com/blacklight-foundation/ultraviolet/blob/main/LICENSE.md',
    label: 'License',
  },
  { href: '/docs/specification/', label: 'Specification' },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Ultraviolet" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={socialImage} />
    <meta property="og:image:secure_url" content={socialImage} />
    <meta property="og:image:type" content={socialImageType} />
    <meta property="og:image:width" content={socialImageWidth} />
    <meta property="og:image:height" content={socialImageHeight} />
    <meta property="og:image:alt" content={socialImageAlt} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={socialImage} />
    <meta name="twitter:image:alt" content={socialImageAlt} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:ital,opsz,wght@0,14..32,100..900;1,14..32,100..900&family=JetBrains+Mono:ital,wght@0,100..800;1,100..800&display=swap" rel="stylesheet" />
    <script is:inline src="/newsletter-signup.js" defer></script>
    <slot name="head" />
  </head>
  <body>
    <div class="announcement-banner">
      <span class="announcement-badge">Public Alpha</span>
      <span class="announcement-message">The Ultraviolet public alpha is available — install the compiler today.</span>
      <a class="announcement-link" href="/releases/">Get the compiler →</a>
    </div>
    <a class="skip-link" href="#content">Skip to content</a>
    <header class="site-header">
      <a class="brand" href="/" aria-label="Ultraviolet home">
        <span class="brand-mark" aria-hidden="true">
          <img
            src="/images/ultraviolet_logo_dark_256.png"
            width="256"
            height="256"
            alt=""
          />
        </span>
        <span class="brand-text">Ultraviolet</span>
      </a>
      <nav class="site-nav" aria-label="Primary navigation">
        {
          navLinks.map((link) => (
            <a
              href={link.href}
              aria-current={
                link.href.startsWith('/') && Astro.url.pathname.startsWith(link.href)
                  ? 'page'
                  : undefined
              }
            >
              {link.label}
            </a>
          ))
        }
      </nav>
      <div class="header-actions">
        <a class="nav-secondary" href="/sponsor/">Support</a>
        <a class="nav-cta" href="/docs/quickstart/">Get started</a>
      </div>
    </header>
    <main id="content">
      <slot />
    </main>
    <footer class="site-footer">
      <div class="footer-inner">
        <div class="footer-primary">
          <a class="footer-brand" href="/">
            <span class="footer-brand-mark" aria-hidden="true">
              <img
                src="/images/ultraviolet_logo_dark_256.png"
                width="256"
                height="256"
                alt=""
              />
            </span>
            <span>Ultraviolet</span>
          </a>
          <div class="footer-stewardship">
            <p class="footer-summary">
              A high-visibility, general-purpose programming language for
              humans and AI, stewarded by Blacklight Foundation.
            </p>
          </div>
          <nav class="footer-links" aria-label="Footer primary navigation">
            {
              footerPrimaryLinks.map((link) => (
                <a href={link.href}>
                  {link.label}
                </a>
              ))
            }
          </nav>
        </div>
        <div class="footer-secondary">
          <form
            class="footer-signup"
            data-newsletter-form
            action="/api/subscribe"
            method="post"
            novalidate
          >
            <input type="hidden" name="source" value="footer" />
            <label class="sr-only" for="footer-newsletter-email">
              Email address
            </label>
            <input
              id="footer-newsletter-email"
              name="email"
              type="email"
              autocomplete="email"
              inputmode="email"
              placeholder="Email for alpha updates"
              required
            />
            <input
              class="newsletter-honeypot"
              name="company"
              type="text"
              tabindex="-1"
              autocomplete="off"
              aria-hidden="true"
            />
            <button type="submit">Subscribe</button>
            <p
              class="footer-signup-status"
              data-newsletter-status
              aria-live="polite"
              aria-atomic="true"
            >
            </p>
          </form>
          <nav class="footer-links footer-utility-links" aria-label="Footer utility navigation">
            {
              footerUtilityLinks.map((link) => (
                <a href={link.href}>
                  {link.label}
                </a>
              ))
            }
          </nav>
          <div class="footer-meta">
            <a
              class="footer-foundation-mark"
              href="/foundation/"
              aria-label="Blacklight Foundation"
            >
              <img
                src="/images/blacklight_wordmark_vertical.png"
                width="600"
                height="600"
                alt=""
              />
            </a>
            <span>&copy; 2026 Blacklight Foundation</span>
            <span>Currently in alpha.</span>
          </div>
        </div>
      </div>
    </footer>
  </body>
</html>
