---
import { constructExplainers } from '../data/homeContent';
import type { LanguageFeature } from '../data/homeContent';
import { highlightPart } from '../utils/highlightPart';

interface Props {
  lines: LanguageFeature['exampleLines'];
  wrapClass?: string;
  codeClass?: string;
}

const { lines, wrapClass = '', codeClass = '' } = Astro.props;
---

<div class={`feature-example-code-wrap ${wrapClass}`.trim()} data-feature-example>
  <pre class={`annotated-code feature-code ${codeClass}`.trim()}><code>{lines.map((line) => (
    <span class="code-line">{line.length === 0 ? ' ' : line.map((part) => {
      if (typeof part === 'string') {
        return highlightPart(part).map(token => {
          if (token.type === 'text') return token.text;
          return <span class={`token-${token.type}`}>{token.text}</span>;
        });
      }
      const explainer = constructExplainers[part.key];
      return (
        <a
          class="code-term"
          href={explainer.href}
          data-title={explainer.title}
          data-body={explainer.body}
          aria-label={`${part.text}: ${explainer.title}. ${explainer.body}`}
        >{part.text}</a>
      );
    })}</span>
  ))}</code></pre>
  <div class="code-tooltip" data-code-tooltip aria-hidden="true"></div>
</div>
