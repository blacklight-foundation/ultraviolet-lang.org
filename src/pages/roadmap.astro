---
import BaseLayout from '../layouts/BaseLayout.astro';
import { roadmapMilestones } from '../data/funding';
import type { RoadmapMilestone } from '../data/funding';

// Engineering-first phases. "Now" is the unfunded baseline work already in
// flight; "Next" features the milestones open for funding today; "Later"
// lists scoped milestones queued behind them, grouped by track so the queue
// stays scannable as it grows.
const currentWork = [
  {
    title: 'Compiler bootstrap hardening',
    body: 'Hardening the source-build path toward the public specification on the first bootstrap target, x86_64-win64.',
    href: '/docs/build-the-compiler/',
    cta: 'Build guide',
  },
  {
    title: 'Release engineering and cadence',
    body: 'Packaged alpha archives with checksums ship on GitHub releases for Linux, macOS, and Windows; current work hardens recurring releases and release notes.',
    href: '/releases/',
    cta: 'Release path',
  },
  {
    title: 'Specification and documentation publication',
    body: 'Keeping the generated specification edition, docs, and examples aligned with the implementation as it converges.',
    href: '/docs/specification/',
    cta: 'Specification',
  },
];

const nextMilestones = roadmapMilestones.filter((m) => m.tone === 'fundable');

const categoryOrder: RoadmapMilestone['category'][] = [
  'Developer Tooling',
  'Core Compiler',
  'Debugging & Diagnostics',
];

const laterTracks = categoryOrder
  .map((category) => ({
    category,
    milestones: roadmapMilestones.filter(
      (m) => m.tone === 'planned' && m.category === category,
    ),
  }))
  .filter((track) => track.milestones.length > 0);
---

<BaseLayout
  title="Public Alpha Roadmap"
  description="Track the Ultraviolet public alpha roadmap: current engineering work, upcoming tooling and compiler milestones, and how funding accelerates each phase."
>
  <article class="article-page status-page roadmap-page">
    <header>
      <p class="eyebrow">Project roadmap</p>
      <h1>Public Alpha Roadmap</h1>
      <p>
        What is being built now, what comes next, and what follows — with the
        funding that accelerates each milestone listed alongside the
        engineering deliverable.
      </p>
      <div class="actions">
        <a class="button primary" href="/releases/">
          View release status
        </a>
        <a class="button secondary" href="/sponsor/#funding-goals">
          Support a funding goal
        </a>
      </div>
    </header>

    <section class="status-page-section" aria-labelledby="roadmap-now-heading">
      <div class="category-header">
        <h2 id="roadmap-now-heading">Now — in progress</h2>
        <p>
          Baseline alpha work underway today, independent of milestone
          funding.
        </p>
      </div>
      <div class="status-card-grid">
        {
          currentWork.map((item) => (
            <a class="card post-card compact-card status-link-card" href={item.href}>
              <span class="status-tag status-now">Now</span>
              <h3>{item.title}</h3>
              <p>{item.body}</p>
              <span class="card-cta">{item.cta}</span>
            </a>
          ))
        }
      </div>
    </section>

    <section class="status-page-section" aria-labelledby="roadmap-next-heading">
      <div class="category-header">
        <h2 id="roadmap-next-heading">Next — open for funding</h2>
        <p>
          Scoped milestones with defined deliverables; each starts as soon as
          its funding goal closes.
        </p>
      </div>
      <div class="milestone-featured-grid">
        {
          nextMilestones.map((milestone) => (
            <article class="milestone-featured">
              <div class="milestone-featured-head">
                <span class="status-tag status-next">Open for funding</span>
                <span class="milestone-featured-category">{milestone.category}</span>
              </div>
              <h3>{milestone.title}</h3>
              <p>{milestone.deliverable}</p>
              <div class="milestone-featured-foot">
                <p class="milestone-featured-target">
                  <strong>{milestone.target}</strong>
                  <span>funding target</span>
                </p>
                <a
                  class="button primary"
                  href={milestone.payLink}
                  target="_blank"
                  rel="noopener noreferrer"
                  aria-label={`Sponsor milestone: ${milestone.title}`}
                >
                  Sponsor this milestone
                </a>
              </div>
            </article>
          ))
        }
      </div>
    </section>

    <section class="status-page-section" aria-labelledby="roadmap-later-heading">
      <div class="category-header">
        <h2 id="roadmap-later-heading">Later — scoped and queued</h2>
        <p>
          Sequenced behind the Next phase and grouped by track. Sponsorship
          pulls a milestone forward.
        </p>
      </div>
      {
        laterTracks.map((track) => (
          <section class="roadmap-track" aria-label={`${track.category} milestones`}>
            <header class="roadmap-track-head">
              <h3>{track.category}</h3>
              <span>
                {track.milestones.length}
                {track.milestones.length === 1 ? ' milestone' : ' milestones'}
              </span>
            </header>
            <ul class="roadmap-track-list">
              {track.milestones.map((milestone) => (
                <li class="roadmap-track-row">
                  <div class="roadmap-track-info">
                    <strong>{milestone.title}</strong>
                    <p>{milestone.deliverable}</p>
                  </div>
                  <div class="roadmap-track-meta">
                    <span class="roadmap-track-target">{milestone.target}</span>
                    <a
                      href={milestone.payLink}
                      target="_blank"
                      rel="noopener noreferrer"
                      aria-label={`Sponsor milestone: ${milestone.title}`}
                    >
                      Sponsor →
                    </a>
                  </div>
                </li>
              ))}
            </ul>
          </section>
        ))
      }
    </section>

    <section class="status-page-section">
      <h2>How this roadmap is maintained</h2>
      <p>
        Phases reflect engineering sequencing, not promises of dates. Work in
        the Now phase ships through the
        <a href="/releases/">release path</a> and is announced in
        <a href="/blog/">Updates</a>. Funding goals and their breakdowns live
        on the <a href="/sponsor/">support page</a>; contribution paths that
        don't involve money live on the
        <a href="/community/">community page</a>.
      </p>
    </section>
  </article>
</BaseLayout>
