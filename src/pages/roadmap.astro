---
import BaseLayout from '../layouts/BaseLayout.astro';

const milestones = [
  {
    title: 'Bootstrap build hardening',
    target: '$7,500',
    status: 'in progress',
    deliverable:
      'Compiler, runtime, and uv source build through a clear public alpha path.',
  },
  {
    title: 'First public example',
    target: '$5,000',
    status: 'fundable',
    deliverable: 'A clean clone/check/build/run path and first maintained .uv example.',
  },
  {
    title: 'CI smoke tests',
    target: '$5,000',
    status: 'fundable',
    deliverable: 'Public smoke tests, build workflow, and release checklist.',
  },
  {
    title: 'Diagnostics examples',
    target: '$15,000',
    status: 'planned',
    deliverable:
      'Maintained examples that demonstrate compiler diagnostics, explicit effects, permissions, and CPU/GPU execution-domain code.',
  },
  {
    title: 'Open LLM training corpus',
    target: '$50,000',
    status: 'fundable',
    deliverable:
      'Open-licensed corpus of examples, constrained tasks, expected outputs, review annotations, diagnostics cases, and evaluation material for LLMs that generate Ultraviolet source.',
  },
  {
    title: 'Self-hosting progress',
    target: '$120,000/year',
    status: 'planned',
    deliverable:
      'Sustained compiler, runtime, release, documentation, contributor, and self-hosting work.',
  },
];
---

<BaseLayout title="Public Alpha Roadmap">
  <article class="article-page roadmap-page">
    <header>
      <p class="eyebrow">Project roadmap</p>
      <h1>Public Alpha Roadmap</h1>
      <p>
        The near-term roadmap is alpha build hardening, a reliable public
        command path, first examples, CI, diagnostics, training material for LLM
        generation, and self-hosting progress.
      </p>
    </header>

    <div class="roadmap-table" aria-label="Public alpha milestones">
      <div class="roadmap-table-head">
        <span>Milestone</span>
        <span>Target</span>
        <span>Status</span>
        <span>Support</span>
      </div>
      {
        milestones.map((milestone) => (
          <section class="roadmap-row">
            <div class="roadmap-main">
              <h2>{milestone.title}</h2>
              <p>{milestone.deliverable}</p>
            </div>
            <strong>{milestone.target}</strong>
            <span class="status-tag">{milestone.status}</span>
            <a href="/sponsor/#funding-goals">Support</a>
          </section>
        ))
      }
    </div>

    <section>
      <h2>Want to support one of these milestones?</h2>
      <div class="actions">
        <a class="button primary" href="/sponsor/#funding-goals">
          Support a milestone
        </a>
      </div>
    </section>
  </article>
</BaseLayout>
