---
import BaseLayout from '../layouts/BaseLayout.astro';
import { roadmapMilestones } from '../data/funding';
import type { RoadmapMilestone } from '../data/funding';

const currentWork = [
  {
    title: 'Compiler bootstrap hardening',
    body: 'Hardening the source-build path toward the public specification and the current bootstrap target reported in the language repository.',
    href: '/docs/build-the-compiler/',
  },
  {
    title: 'Release engineering and cadence',
    body: 'Packaged archives, checksum metadata, and validation state are reported from GitHub releases and Actions; current work hardens recurring releases and release notes.',
    href: '/releases/',
  },
  {
    title: 'Specification and documentation',
    body: 'Keeping the generated specification edition, docs, and examples aligned with the implementation as it converges.',
    href: '/docs/specification/',
  },
];

const nextMilestones = roadmapMilestones.filter((milestone) => milestone.tone === 'fundable');
const plannedMilestones = roadmapMilestones.filter((milestone) => milestone.tone === 'planned');

const categoryOrder: RoadmapMilestone['category'][] = [
  'Developer Tooling',
  'Core Compiler',
  'Debugging & Diagnostics',
];

const laterTracks = categoryOrder
  .map((category) => ({
    category,
    milestones: plannedMilestones.filter((milestone) => milestone.category === category),
  }))
  .filter((track) => track.milestones.length > 0);
---

<BaseLayout
  title="Public Alpha Roadmap"
  description="Track the Ultraviolet public alpha roadmap: current engineering work, upcoming tooling and compiler milestones, and how funding accelerates each phase."
>
  <article class="ddp-page roadmap-page">
    <header class="ddp-head">
      <div class="dd-wrap ddp-head-in">
        <p class="ddp-kicker">Project roadmap</p>
        <h1 class="ddp-h1">Public Alpha Roadmap</h1>
        <p class="ddp-lede">
          What is being built now, what comes next, and what follows — with the
          funding that accelerates each milestone listed alongside the
          engineering deliverable.
        </p>
        <div class="ddp-actions">
          <a class="dd-btn-primary" href="/releases/">View release status</a>
          <a class="dd-btn-ghost" href="/sponsor/#funding-goals">Support a funding goal</a>
        </div>
      </div>
    </header>

    <div class="dd-wrap">
      <div class="ddp-counts" aria-label="Roadmap counts">
        <div class="ddp-count"><b>{currentWork.length}</b><span>in progress now</span></div>
        <div class="ddp-count"><b>{nextMilestones.length}</b><span>open for funding</span></div>
        <div class="ddp-count"><b>{plannedMilestones.length}</b><span>scoped and queued</span></div>
      </div>

      <section class="ddp-section" aria-labelledby="roadmap-now-heading">
        <div class="ddp-section-head">
          <span class="dd-section-no"><b>01</b> / NOW</span>
          <div>
            <h2 class="ddp-h2" id="roadmap-now-heading">In progress.</h2>
            <p class="dd-section-sub">
              Baseline alpha work underway today, independent of milestone funding.
            </p>
          </div>
        </div>
        {
          currentWork.map((item) => (
            <a class="ddp-row ddp-row-three ddp-linked-row" href={item.href}>
              <p class="ddp-row-t">{item.title}</p>
              <p class="ddp-row-d">{item.body}</p>
              <span class="ddp-row-status"><span class="ddp-tag now">Now</span></span>
            </a>
          ))
        }
      </section>

      <section class="ddp-section" aria-labelledby="roadmap-next-heading">
        <div class="ddp-section-head">
          <span class="dd-section-no"><b>02</b> / NEXT</span>
          <div>
            <h2 class="ddp-h2" id="roadmap-next-heading">Open for funding.</h2>
            <p class="dd-section-sub">
              Scoped milestones with defined deliverables; each starts as soon
              as its funding goal closes.
            </p>
          </div>
        </div>
        {
          nextMilestones.map((milestone) => (
            <article class="ddp-row fundable">
              <p class="ddp-row-t">
                {milestone.title}
                <span class="ddp-row-cat">{milestone.category}</span>
              </p>
              <p class="ddp-row-d">{milestone.deliverable}</p>
              <span class="ddp-row-target">{milestone.target}</span>
              <span class="ddp-row-cta">
                <a
                  class="dd-btn-primary"
                  href={milestone.payLink}
                  target="_blank"
                  rel="noopener noreferrer"
                  aria-label={`Sponsor milestone: ${milestone.title}`}
                >
                  Sponsor this milestone
                </a>
              </span>
            </article>
          ))
        }
      </section>

      <section class="ddp-section" aria-labelledby="roadmap-later-heading">
        <div class="ddp-section-head">
          <span class="dd-section-no"><b>03</b> / LATER</span>
          <div>
            <h2 class="ddp-h2" id="roadmap-later-heading">Scoped and queued.</h2>
            <p class="dd-section-sub">
              Sequenced behind the Next phase and grouped by track. Sponsorship
              pulls a milestone forward.
            </p>
          </div>
        </div>
        {
          laterTracks.map((track) => (
            <section aria-label={`${track.category} milestones`}>
              <div class="ddp-track-head">
                <h3>{track.category}</h3>
                <span>
                  {track.milestones.length}
                  {track.milestones.length === 1 ? ' milestone' : ' milestones'}
                </span>
              </div>
              {track.milestones.map((milestone) => (
                <article class="ddp-row">
                  <p class="ddp-row-t">{milestone.title}</p>
                  <p class="ddp-row-d">{milestone.deliverable}</p>
                  <span class="ddp-row-target">{milestone.target}</span>
                  <span class="ddp-row-status"><span class="ddp-tag planned">Planned</span></span>
                </article>
              ))}
            </section>
          ))
        }
      </section>
      <div class="ddp-bottom-pad"></div>
    </div>
  </article>
</BaseLayout>
