---
import BaseLayout from '../layouts/BaseLayout.astro';

const milestones = [
  {
    title: 'Bootstrap build hardening',
    target: '$7,500',
    status: 'Now',
    tone: 'now',
    deliverable:
      'Compiler, runtime, and uv source build through a clear public alpha path.',
  },
  {
    title: 'First public example',
    target: '$5,000',
    status: 'Fundable',
    tone: 'fundable',
    deliverable: 'A clean clone/check/build/run path and first maintained .uv example.',
  },
  {
    title: 'CI smoke tests',
    target: '$5,000',
    status: 'Fundable',
    tone: 'fundable',
    deliverable: 'Public smoke tests, build workflow, and release checklist.',
  },
  {
    title: 'Diagnostics examples',
    target: '$15,000',
    status: 'Planned',
    tone: 'planned',
    deliverable:
      'Maintained examples that demonstrate compiler diagnostics, contracts, modals, permissions, keys, and CPU/GPU execution-domain code.',
  },
  {
    title: 'Open LLM training corpus',
    target: '$50,000',
    status: 'Fundable',
    tone: 'fundable',
    deliverable:
      'Open-licensed corpus of examples, constrained tasks, expected outputs, review annotations, diagnostics cases, and evaluation material for LLMs that generate Ultraviolet source.',
  },
  {
    title: 'Self-hosting progress',
    target: '$120,000/year',
    status: 'Planned',
    tone: 'planned',
    deliverable:
      'Sustained compiler, runtime, release, documentation, contributor, and self-hosting work.',
  },
];
---

<BaseLayout
  title="Public Alpha Roadmap"
  description="Track the Ultraviolet public alpha roadmap, funding targets, milestone status, and next compiler, release, documentation, and training-corpus work."
>
  <article class="article-page status-page roadmap-page">
    <header>
      <p class="eyebrow">Project roadmap</p>
      <h1>Public Alpha Roadmap</h1>
      <p>
        The near-term roadmap is alpha build hardening, a reliable public
        command path, first examples, CI, diagnostics, training material for LLM
        generation, and self-hosting progress.
      </p>
      <div class="actions">
        <a class="button primary" href="/sponsor/#funding-goals">
          Support a milestone
        </a>
        <a class="button secondary" href="/releases/">
          View release status
        </a>
      </div>
    </header>

    <section class="status-page-section" aria-labelledby="roadmap-milestones-heading">
      <h2 id="roadmap-milestones-heading">Milestones</h2>
      <div class="milestone-grid">
        {
          milestones.map((milestone) => (
            <article class="card milestone-card">
              <div class="milestone-card-head">
                <span class={`status-tag status-${milestone.tone}`}>{milestone.status}</span>
                <h3>{milestone.title}</h3>
              </div>
              <p>{milestone.deliverable}</p>
              <dl class="milestone-meta">
                <div>
                  <dt>Funding target</dt>
                  <dd>{milestone.target}</dd>
                </div>
                <div>
                  <dt>Status</dt>
                  <dd>{milestone.status}</dd>
                </div>
              </dl>
              <a
                class="card-cta"
                href="/sponsor/#funding-goals"
                aria-label={`Support ${milestone.title}`}
              >
                Support this milestone
              </a>
            </article>
          ))
        }
      </div>
    </section>
  </article>
</BaseLayout>
