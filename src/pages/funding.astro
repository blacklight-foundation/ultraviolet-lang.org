---
import BaseLayout from '../layouts/BaseLayout.astro';
import {
  fundingGoals,
  sponsorFundedWork,
  sponsorshipOptions,
} from '../data/funding';
---

<BaseLayout title="Fund Ultraviolet">
  <article class="article-page">
    <header>
      <p class="eyebrow">Funding goals</p>
      <h1>Fund Ultraviolet</h1>
      <p>
        Blacklight Foundation funds the public infrastructure for a systems
        language designed for generated code humans can still review.
      </p>
      <div class="actions">
        <a class="button primary" href="mailto:sponsors@ultraviolet-lang.org">
          Become a founding sponsor
        </a>
        <a class="button secondary" href="/sponsor/">View sponsor options</a>
      </div>
    </header>

    <section>
      <h2>Funding pitch</h2>
      <p>Generated code is no longer disposable.</p>
      <p>
        It is reviewed, debugged, diffed, audited, shipped, and trusted in
        production. SDKs, bindings, schema compilers, infrastructure tools, DSLs,
        and AI-assisted systems all emit code that humans still need to
        understand.
      </p>
      <p>
        Most programming languages were designed primarily for humans writing
        code by hand.
      </p>
      <p>Ultraviolet explores a narrower question:</p>
      <p>
        <strong>
          What should a systems programming language look like if generated-code
          reviewability is a first-class design constraint?
        </strong>
      </p>
      <p>
        Ultraviolet is currently in alpha. A functional bootstrap compiler
        exists, and Blacklight Foundation is funding the public work needed to
        make Ultraviolet credible, buildable, documented, and useful to early
        evaluators.
      </p>
      <p>Sponsor funding supports public infrastructure:</p>
      <ul class="plain-list">
        {sponsorFundedWork.map((item) => <li>{item}</li>)}
      </ul>
      <p>
        We are not asking sponsors to bet that Ultraviolet has already won.
      </p>
      <p>
        We are asking sponsors to fund a serious public experiment in reviewable
        generated systems code.
      </p>
      <p>
        If your company cares about code generation, SDKs, compilers, static
        analysis, developer tools, infrastructure, security, or AI-generated
        code, this work is probably adjacent to your future.
      </p>
    </section>

    {
      fundingGoals.map((fund) => (
        <section>
          <h2>{fund.title}</h2>
          <div class="card funding-card">
            <p class="funding-goal">Goal: {fund.goal}</p>
            <p class="funding-timeline">Timeline: {fund.timeline}</p>
            <p>{fund.summary}</p>
            <p>{fund.body}</p>
            <p>{fund.outcome}</p>
            <ul class="plain-list">
              {fund.breakdown.map((item) => (
                <li>{item}</li>
              ))}
            </ul>
            <div class="actions">
              <a class="button ghost" href={fund.href}>
                {fund.cta}
              </a>
            </div>
          </div>
        </section>
      ))
    }

    <section>
      <h2>Sponsorship options</h2>
      <div class="grid three-col">
        {
          sponsorshipOptions.map((tier) => (
            <article class="card">
              <h3>{tier.title}</h3>
              <p class="tier-price">{tier.price}</p>
              <p>{tier.audience}</p>
              <ul class="plain-list">
                {tier.benefits.map((benefit) => (
                  <li>{benefit}</li>
                ))}
              </ul>
              <div class="actions">
                <a
                  class="button ghost"
                  href={`mailto:sponsors@ultraviolet-lang.org?subject=${encodeURIComponent(tier.title)}`}
                >
                  {tier.cta}
                </a>
              </div>
            </article>
          ))
        }
      </div>
      <p>
        Sponsor recognition is neutral and focused on public thanks,
        transparency, reporting, and milestone completion.
      </p>
      <p>
        Example recognition: Thank you to SponsorCo for supporting the
        Ultraviolet public alpha.
      </p>
    </section>

    <section>
      <h2>Contact</h2>
      <p>
        Sponsor conversations can start by email:
        <a href="mailto:sponsors@ultraviolet-lang.org">
          sponsors@ultraviolet-lang.org
        </a>.
      </p>
      <div class="actions">
        <a class="button primary" href="mailto:sponsors@ultraviolet-lang.org">
          Become a founding sponsor
        </a>
      </div>
    </section>
  </article>
</BaseLayout>
