---
import BaseLayout from '../layouts/BaseLayout.astro';

const repoUrl = 'https://github.com/blacklight-foundation/ultraviolet';

const channels = [
  {
    intent: 'Ask a question',
    venue: 'GitHub Discussions',
    body: 'Share what you are building and propose ideas before opening large changes.',
    href: `${repoUrl}/discussions`,
    cta: 'Open Discussions',
  },
  {
    intent: 'Report a bug',
    venue: 'Issue tracker',
    body: 'Compiler, runtime, toolchain, handbook, and documentation problems against the alpha.',
    href: `${repoUrl}/issues`,
    cta: 'Open Issues',
  },
  {
    intent: 'Read the source',
    venue: 'Language repository',
    body: 'Compiler, runtime, uv tool, handbook, and conformance material — all public, Apache-2.0.',
    href: repoUrl,
    cta: 'Browse the repo',
  },
];

const contributions = [
  {
    title: 'Test the alpha on your platform',
    body: 'Run the installer or build from source, then report exactly what breaks. Install and build reports across platforms are the highest-leverage contribution right now.',
    href: '/releases/#install',
    cta: 'Get the installer',
  },
  {
    title: 'Review the handbook',
    body: 'The handbook is the source of truth. Ambiguities, contradictions, and unclear judgments are bugs — file them like any other defect.',
    href: '/docs/handbook/',
    cta: 'Read the handbook',
  },
  {
    title: 'Improve docs and examples',
    body: 'Docs gaps, broken walkthroughs, and missing examples block adopters before the compiler does.',
    href: `${repoUrl}/pulls`,
    cta: 'Open pull requests',
  },
  {
    title: 'Evaluate AI-written Ultraviolet',
    body: 'Generate Ultraviolet with your preferred model, audit it against the review model, and share findings.',
    href: '/docs/handbook/30-style-best-practices/',
    cta: 'Read the review model',
  },
];
---

<BaseLayout
  title="Community"
  description="Join the Ultraviolet community: ask questions in GitHub Discussions, report alpha bugs, contribute code, docs, and examples, and follow public updates."
>
  <article class="ddp-page community-page">
    <header class="ddp-head">
      <div class="dd-wrap ddp-head-in">
        <p class="ddp-kicker">Community</p>
        <h1 class="ddp-h1">Community</h1>
        <p class="ddp-lede">
          Ultraviolet is built in public. Questions, bug reports, handbook review,
          docs fixes, and code contributions all happen in the open — no money
          required.
        </p>
        <div class="ddp-actions">
          <a class="dd-btn-primary" href={`${repoUrl}/discussions`}>Ask a question</a>
          <a class="dd-btn-ghost" href={`${repoUrl}/issues`}>Report a bug</a>
        </div>
      </div>
    </header>

    <div class="dd-wrap">
      <section class="ddp-section" aria-labelledby="community-start-heading">
        <div class="ddp-section-head">
          <span class="dd-section-no"><b>01</b> / START</span>
          <div>
            <h2 class="ddp-h2" id="community-start-heading">Find the right venue.</h2>
            <p class="dd-section-sub">
              Everything happens on GitHub — pick the door that matches what you came to do.
            </p>
          </div>
        </div>
        {
          channels.map((channel) => (
            <a class="ddp-route-row" href={channel.href} target="_blank" rel="noopener noreferrer">
              <p class="ddp-route-intent">{channel.intent}</p>
              <p class="ddp-route-d"><b>{channel.venue}.</b> {channel.body}</p>
              <span class="ddp-cell-cta">{channel.cta} →</span>
            </a>
          ))
        }
      </section>

      <section class="ddp-section" aria-labelledby="community-contribute-heading">
        <div class="ddp-section-head">
          <span class="dd-section-no"><b>02</b> / CONTRIBUTE</span>
          <div>
            <h2 class="ddp-h2" id="community-contribute-heading">Highest-leverage contributions first.</h2>
            <p class="dd-section-sub">
              During the alpha, these four things move the project most — in this order.
            </p>
          </div>
        </div>
        {
          contributions.map((item, index) => (
            <a class="ddp-prio-row" href={item.href}>
              <span class="ddp-prio-no">{String(index + 1).padStart(2, '0')}</span>
              <p class="ddp-row-t">{item.title}</p>
              <p class="ddp-row-d">{item.body}</p>
              <span class="ddp-cell-cta">{item.cta} →</span>
            </a>
          ))
        }
      </section>
      <div class="ddp-bottom-pad"></div>
    </div>
  </article>
</BaseLayout>
