---
import BaseLayout from '../layouts/BaseLayout.astro';
import NewsletterSignup from '../components/NewsletterSignup.astro';
import {
  fundingGoals,
  oneTimeDonation,
  supportFundedWork,
  supportTiers,
} from '../data/funding';

const trustSignals = [
  'Public repo',
  'Public roadmap',
  'Foundation stewardship',
  'Public reporting',
];

const fundedAreas = [
  {
    title: 'Buildable public alpha',
    body: 'Build hardening, first examples, smoke tests, and a clear build/check path.',
  },
  {
    title: 'Open LLM training corpus',
    body: 'Canonical examples, constrained tasks, expected outputs, diagnostics cases, CPU/GPU examples, and review annotations.',
  },
  {
    title: 'Sustained maintainer time',
    body: 'Release engineering, documentation, examples, contributor support, and public updates.',
  },
];
---

<BaseLayout title="Support Ultraviolet">
  <article class="article-page support-page">
    <header>
      <p class="eyebrow">Public alpha support</p>
      <h1>Support Ultraviolet</h1>
      <p>
        Recurring support and targeted funding for the Ultraviolet public alpha.
      </p>
      <div class="actions">
        <a class="button primary" href="#support-tiers">Support now</a>
        <a class="button secondary" href="#funding-goals">Funding goals</a>
        <a class="button ghost" href="#donate">Donate once</a>
      </div>
    </header>

    <section class="support-intro">
      <h2>Why support?</h2>
      <p>
        Ultraviolet is currently in alpha. The language is designed for
        generated source that exposes effects, authority, permission,
        responsibility, execution domain, and runtime opt-ins directly in code.
      </p>
      <p>
        Public support helps Blacklight Foundation turn the current alpha
        compiler and specification into a buildable public project with docs,
        examples, CI, diagnostics, CPU/GPU language work, an open LLM training
        corpus, and public release infrastructure.
      </p>
      <div class="trust-strip" aria-label="Trust signals">
        {trustSignals.map((signal) => <span>{signal}</span>)}
      </div>
    </section>

    <section id="support-tiers">
      <h2>Recurring support</h2>
      <p>
        Choose a monthly support amount and complete payment through Stripe.
      </p>
      <div class="support-amount-grid">
        {
          supportTiers.map((tier) => (
            <a class="support-amount" href={tier.href} aria-label={tier.cta}>
              <span>{tier.amount}</span>
              <strong>{tier.title}</strong>
              <small>{tier.description}</small>
            </a>
          ))
        }
      </div>
      <p>
        For invoices, ACH, custom recognition, grant paperwork, or larger
        support arrangements, email <a href="mailto:sponsors@ultraviolet-lang.org">sponsors@ultraviolet-lang.org</a>
      </p>
    </section>

    <section id="donate" class="card donation-card">
      <div>
        <h2>{oneTimeDonation.title}</h2>
        <p>
          {oneTimeDonation.description} Use this for a flexible one-time
          contribution.
        </p>
      </div>
      <a class="button primary" href={oneTimeDonation.href}>
        {oneTimeDonation.cta}
      </a>
    </section>

    <section>
      <h2>What support funds</h2>
      <div class="grid three-col">
        {
          fundedAreas.map((item) => (
            <article class="card compact-card">
              <h3>{item.title}</h3>
              <p>{item.body}</p>
            </article>
          ))
        }
      </div>
    </section>

    <section id="funding-goals">
      <h2>Targeted funding goals</h2>
      <div class="funding-goal-list">
        {
          fundingGoals.map((fund) => (
            <section class="card funding-card funding-goal-card">
              <div>
                <h3>{fund.title}</h3>
                <p class="funding-goal">Goal: {fund.goal}</p>
                <p class="funding-timeline">Timeline: {fund.timeline}</p>
              </div>
              <div>
                <p>{fund.summary}</p>
                <p>{fund.body}</p>
                <p>{fund.outcome}</p>
              </div>
              <ul class="plain-list funding-breakdown">
                {fund.breakdown.map((item) => (
                  <li>{item}</li>
                ))}
              </ul>
              <div class="actions">
                <a class="button ghost" href={fund.href}>
                  {fund.cta}
                </a>
              </div>
            </section>
          ))
        }
      </div>
    </section>

    <section>
      <h2>Public work covered by support</h2>
      <ul class="plain-list">
        {supportFundedWork.map((item) => <li>{item}</li>)}
      </ul>
    </section>

    <NewsletterSignup
      source="support"
      heading="Follow the public alpha"
      description="Get compiler progress, funding milestones, and public alpha updates."
    />

    <section>
      <h2>Contact</h2>
      <p>
        Questions, invoices, ACH, grant paperwork, and larger support
        conversations can start by email: <a href="mailto:sponsors@ultraviolet-lang.org">sponsors@ultraviolet-lang.org</a>
      </p>
    </section>
  </article>
</BaseLayout>
