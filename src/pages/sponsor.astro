---
import BaseLayout from '../layouts/BaseLayout.astro';
import {
  fundingGoals,
  oneTimeDonation,
  supportTiers,
} from '../data/funding';

const trustSignals = [
  'Public repository',
  'Public roadmap',
  'Foundation stewardship',
  'Transparent reporting',
];

const selectedTierIndex = Math.min(2, supportTiers.length - 1);
const selectedTier = supportTiers[selectedTierIndex];

const splitBreakdown = (item: string) => {
  const [amount, ...rest] = item.split(' ');
  return { amount, detail: rest.join(' ') };
};
---

<BaseLayout
  title="Support Ultraviolet"
  description="Support Ultraviolet through monthly sponsorship or targeted public alpha funding goals."
>
  <article class="ddp-page support-page">
    <header class="ddp-head">
      <div class="dd-wrap ddp-head-in">
        <p class="ddp-kicker">Public alpha support</p>
        <h1 class="ddp-h1">Support Ultraviolet</h1>
        <p class="ddp-lede">
          Your support enables Blacklight Foundation to maintain Ultraviolet as a
          public utility — keeping the compiler toolchain, documentation,
          packaging infrastructure, and specification completely free,
          open-source, and independent.
        </p>
        <div class="ddp-trust" aria-label="Trust signals">
          {trustSignals.map((signal) => <span class="ddp-tag">{signal}</span>)}
        </div>
      </div>
    </header>

    <div class="dd-wrap">
      <section class="ddp-section" aria-label="Support paths">
        <div class="ddp-fork">
          <div class="ddp-fork-cell">
            <p class="label">Path A · Recurring</p>
            <p class="t">Monthly sponsorship</p>
            <p class="d">
              General support that funds ongoing maintenance, package hosting,
              CI, and documentation. Pick an amount, pay through Stripe.
            </p>
            <a class="dd-btn-primary" href="#choose">Choose an amount ↓</a>
          </div>
          <div class="ddp-fork-cell">
            <p class="label">Path B · Targeted</p>
            <p class="t">Fund a milestone</p>
            <p class="d">
              One-time contributions toward a scoped deliverable — LSP tooling,
              the standard library, or the Wasm playground — each with a
              published cost breakdown.
            </p>
            <a class="dd-btn-ghost" href="#funding-goals">See funding goals ↓</a>
          </div>
        </div>
      </section>

      <section class="ddp-section" id="choose" aria-labelledby="recurring-heading" data-support-picker>
        <div class="ddp-section-head">
          <span class="dd-section-no"><b>01</b> / RECURRING</span>
          <div>
            <h2 class="ddp-h2" id="recurring-heading">Choose a monthly amount.</h2>
            <p class="dd-section-sub">
              Every tier funds the same public work and includes public roadmap
              updates — the amount is up to you.
            </p>
          </div>
        </div>
        <div class="ddp-amounts" role="radiogroup" aria-label="Monthly support amount">
          {
            supportTiers.map((tier, index) => (
              <button
                type="button"
                role="radio"
                aria-checked={index === selectedTierIndex ? 'true' : 'false'}
                class:list={['ddp-amount', index === selectedTierIndex && 'selected']}
                data-support-tier={index}
                data-support-label={`Support at ${tier.amount}/month`}
                data-support-href={tier.href}
              >
                {tier.amount === '$20' && <span class="rec">Most common</span>}
                <span class="amt">{tier.amount}</span>
                <span class="name">{tier.title}</span>
              </button>
            ))
          }
        </div>
        <div class="ddp-amount-foot">
          <p class="ddp-benefit-line">
            Funds <b>compiler maintenance, package hosting, CI/CD, and documentation</b>
            {' '}· includes public roadmap updates · cancel anytime.
          </p>
          <a
            class="dd-btn-primary"
            href={selectedTier.href}
            target="_blank"
            rel="noopener noreferrer"
            data-support-cta
          >
            Support at {selectedTier.amount}/month
          </a>
        </div>
        <p class="ddp-fineprint">
          For invoices, ACH, custom recognition, grant paperwork, or larger
          support arrangements, email
          <a href="mailto:sponsors@ultraviolet-lang.org">sponsors@ultraviolet-lang.org</a>
        </p>
        <div class="ddp-donate-row" id="donate">
          <div>
            <p class="t">{oneTimeDonation.title}</p>
            <p class="d">{oneTimeDonation.description}</p>
          </div>
          <a class="dd-btn-ghost" href={oneTimeDonation.href} target="_blank" rel="noopener noreferrer">
            {oneTimeDonation.cta}
          </a>
        </div>
      </section>

      <section class="ddp-section" id="funding-goals" aria-labelledby="targeted-heading">
        <div class="ddp-section-head">
          <span class="dd-section-no"><b>02</b> / TARGETED</span>
          <div>
            <h2 class="ddp-h2" id="targeted-heading">Targeted funding goals.</h2>
            <p class="dd-section-sub">
              Each goal funds a scoped milestone with a public deliverable and a
              published cost breakdown.
            </p>
          </div>
        </div>
        {
          fundingGoals.map((fund) => (
            <article class="ddp-goal">
              <div>
                <p class="ddp-goal-t">{fund.title}</p>
                <span class="ddp-goal-amount"><b>{fund.goal}</b>funding goal</span>
                <p class="ddp-goal-timeline">Timeline: {fund.timeline}</p>
                <a class="dd-btn-ghost" href={fund.payLink} target="_blank" rel="noopener noreferrer">
                  {fund.cta}
                </a>
              </div>
              <div class="ddp-goal-body">
                <p>{fund.summary}</p>
                <p><b>Outcome:</b> {fund.outcome}</p>
              </div>
              <div>
                <p class="ddp-goal-breakdown-label">Breakdown</p>
                <ul class="ddp-goal-breakdown">
                  {fund.breakdown.map((item) => {
                    const breakdown = splitBreakdown(item);
                    return <li><b>{breakdown.amount}</b> {breakdown.detail}</li>;
                  })}
                </ul>
              </div>
            </article>
          ))
        }
      </section>
      <div class="ddp-bottom-pad"></div>
    </div>
  </article>
</BaseLayout>
