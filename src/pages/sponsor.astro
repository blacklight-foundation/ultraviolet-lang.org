---
import BaseLayout from '../layouts/BaseLayout.astro';
import NewsletterSignup from '../components/NewsletterSignup.astro';
import {
  fundingGoals,
  oneTimeDonation,
  supportFundedWork,
  supportTiers,
} from '../data/funding';

const trustSignals = [
  'Public repository',
  'Public roadmap',
  'Foundation stewardship',
  'Transparent reporting',
];

const fundedAreas = [
  {
    title: 'Robust Developer Tooling',
    body: 'Compiler speed optimization, Language Server Protocol (LSP) IDE integration, packages management, and formatting check paths.',
  },
  {
    title: 'Core Language Safety',
    body: 'Enforcing runtime sandboxing, static defaults, explicit capability verification, and responsibility-transfer checks.',
  },
  {
    title: 'Sustained Maintainer Support',
    body: 'Release engineering orchestration, diagnostics tutorials, developer advocacy, and public roadmap reporting.',
  },
];
---

<BaseLayout title="Support Ultraviolet">
  <article class="article-page support-page">
    <header>
      <p class="eyebrow">Public alpha support</p>
      <h1>Support Ultraviolet</h1>
      <p>
        General recurring sponsorship and targeted milestone funding to build a safe, high-visibility compiler.
      </p>
      <div class="actions">
        <a class="button primary" href="#support-tiers">Support now</a>
        <a class="button secondary" href="#funding-goals">Funding goals</a>
        <a class="button ghost" href="#donate">Donate once</a>
      </div>
    </header>

    <section class="support-intro">
      <h2>Why support?</h2>
      <p>
        Ultraviolet is built from the ground up for safe, high-performance programming.
        By centering language design around explicit capabilities, sandboxed system APIs,
        and compiler-verified responsibility transfers, Ultraviolet prevents safety bugs before they run,
        making it perfect for humans and AI agents alike.
      </p>
      <p>
        Your support enables the Blacklight Foundation to maintain Ultraviolet as a public utility—keeping
        the compiler toolchain, documentation, packaging infrastructure, and specification completely free,
        open-source, and independent.
      </p>
      <div class="foundation-steward-card">
        <img
          src="/images/blacklight_wordmark_vertical.png"
          width="600"
          height="600"
          alt="Blacklight Foundation"
        />
        <p>
          Donations and sponsorships support Blacklight Foundation's public
          Ultraviolet work.
        </p>
      </div>
      <div class="trust-strip" aria-label="Trust signals">
        {trustSignals.map((signal) => <span>{signal}</span>)}
      </div>
    </section>

    <section id="support-tiers">
      <h2>Recurring support</h2>
      <p>
        Support the project with a recurring monthly contribution through Stripe. General sponsorship funds ongoing maintenance, package hosting, and documentation.
      </p>
      <div class="support-amount-grid">
        {
          supportTiers.map((tier) => (
            <a class="support-amount" href={tier.href} target="_blank" rel="noopener noreferrer" aria-label={tier.cta}>
              <span>{tier.amount}</span>
              <strong>{tier.title}</strong>
              <small>{tier.description}</small>
              <ul class="tier-benefits-list">
                {tier.benefits.map((b) => (
                  <li>{b}</li>
                ))}
              </ul>
            </a>
          ))
        }
      </div>
      <p>
        For invoices, ACH, custom recognition, grant paperwork, or larger
        support arrangements, email <a href="mailto:sponsors@ultraviolet-lang.org">sponsors@ultraviolet-lang.org</a>
      </p>
    </section>

    <section id="donate" class="card donation-card">
      <div>
        <h2>{oneTimeDonation.title}</h2>
        <p>
          {oneTimeDonation.description} Use this for a flexible one-time
          contribution.
        </p>
      </div>
      <a class="button primary" href={oneTimeDonation.href} target="_blank" rel="noopener noreferrer">
        {oneTimeDonation.cta}
      </a>
    </section>

    <section>
      <h2>What support funds</h2>
      <div class="grid three-col">
        {
          fundedAreas.map((item) => (
            <article class="card compact-card">
              <h3>{item.title}</h3>
              <p>{item.body}</p>
            </article>
          ))
        }
      </div>
    </section>

    <section id="funding-goals">
      <h2>Targeted funding goals</h2>
      <div class="funding-goal-list">
        {
          fundingGoals.map((fund) => (
            <section class="card funding-card funding-goal-card">
              <div>
                <h3>{fund.title}</h3>
                <p class="funding-goal">Goal: {fund.goal}</p>
                <p class="funding-timeline">Timeline: {fund.timeline}</p>
              </div>
              <div>
                <p>{fund.summary}</p>
                <p>{fund.body}</p>
                <p>{fund.outcome}</p>
              </div>
              <ul class="plain-list funding-breakdown">
                {fund.breakdown.map((item) => (
                  <li>{item}</li>
                ))}
              </ul>
              <div class="actions">
                <a class="button ghost" href={fund.payLink} target="_blank" rel="noopener noreferrer">
                  Sponsor this goal
                </a>
              </div>
            </section>
          ))
        }
      </div>
    </section>

    <section>
      <h2>Public work covered by support</h2>
      <ul class="plain-list">
        {supportFundedWork.map((item) => <li>{item}</li>)}
      </ul>
    </section>

    <NewsletterSignup
      source="support"
      heading="Follow the public alpha"
      description="Get compiler progress, funding milestones, and public alpha updates."
    />

    <section>
      <h2>Contact</h2>
      <p>
        Questions, invoices, ACH, grant paperwork, and larger support
        conversations can start by email: <a href="mailto:sponsors@ultraviolet-lang.org">sponsors@ultraviolet-lang.org</a>
      </p>
    </section>
  </article>
</BaseLayout>
