---
import BaseLayout from '../layouts/BaseLayout.astro';
import NewsletterSignup from '../components/NewsletterSignup.astro';
import {
  sponsorFundedWork,
  sponsorPaymentLinks,
  sponsorshipOptions,
} from '../data/funding';
---

<BaseLayout title="Sponsor Ultraviolet">
  <article class="article-page">
    <header>
      <p class="eyebrow">Public alpha funding</p>
      <h1>Sponsor Ultraviolet</h1>
      <p>
        Support the public alpha of a systems language for reviewable
        LLM-generated code.
      </p>
      <div class="actions">
        <a class="button primary" href="#sponsor-now">Sponsor now</a>
        <a class="button secondary" href="/funding/">See funding goals</a>
        <a class="button ghost" href="mailto:sponsors@ultraviolet-lang.org">
          Email sponsors
        </a>
      </div>
    </header>

    <section id="sponsor-now">
      <h2>Sponsor now</h2>
      <p>
        Choose a sponsorship amount and complete payment through Stripe.
      </p>
      <div class="payment-grid">
        {
          sponsorPaymentLinks.map((link) => (
            <article class="card payment-card">
              <h3>{link.amount}</h3>
              <p>Support the Ultraviolet public alpha.</p>
              <a
                class="button primary"
                href={link.href}
                aria-label={link.label}
              >
                {link.label}
              </a>
            </article>
          ))
        }
      </div>
      <p>
        For invoices, ACH, custom sponsor recognition, grant paperwork, or
        larger sponsorships, email
        <a href="mailto:sponsors@ultraviolet-lang.org">
          sponsors@ultraviolet-lang.org
        </a>.
      </p>
    </section>

    <section>
      <h2>Why sponsor?</h2>
      <p>
        Ultraviolet is early, but the thesis is concrete: LLM-generated systems
        code should be explicit, predictable, and reviewable.
      </p>
      <p>
        Sponsor funding helps Blacklight Foundation turn the current alpha
        compiler and specification into a usable public project with docs,
        examples, CI, diagnostics, and a first LLM-generated code demo.
      </p>
      <NewsletterSignup
        source="sponsor"
        heading="Follow the public alpha"
        description="Get compiler progress, funding milestones, and public alpha updates before you sponsor."
      />
    </section>

    <section>
      <h2>Sponsorship options</h2>
      <div class="grid three-col">
        {
          sponsorshipOptions.map((tier) => (
            <article class="card">
              <h3>{tier.title}</h3>
              <p class="tier-price">{tier.price}</p>
              <p>{tier.audience}</p>
              <ul class="plain-list">
                {tier.benefits.map((benefit) => (
                  <li>{benefit}</li>
                ))}
              </ul>
              <div class="actions">
                <a
                  class="button ghost"
                  href={`mailto:sponsors@ultraviolet-lang.org?subject=${encodeURIComponent(tier.title)}`}
                >
                  {tier.cta}
                </a>
              </div>
            </article>
          ))
        }
      </div>
    </section>

    <section>
      <h2>What sponsor money funds</h2>
      <ul class="plain-list">
        {sponsorFundedWork.map((item) => <li>{item}</li>)}
      </ul>
    </section>

    <section>
      <h2>Contact</h2>
      <p>
        Sponsor conversations can start by email:
        <a href="mailto:sponsors@ultraviolet-lang.org">
          sponsors@ultraviolet-lang.org
        </a>.
      </p>
    </section>
  </article>
</BaseLayout>
