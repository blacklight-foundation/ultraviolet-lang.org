---
import InstallTabs from '../components/InstallTabs.astro';
import ReleaseStatusStrip from '../components/ReleaseStatusStrip.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import { getReleaseStatus } from '../data/releaseStatus';

const releaseStatus = await getReleaseStatus();

const releaseTimeline = [
  {
    title: 'Build verification',
    status: 'Now',
    tone: 'now',
    body: 'Build checks, prerequisite validation, and documented verification for local source builds.',
  },
  {
    title: 'Packaged artifacts',
    status: 'Available',
    tone: 'now',
    body: 'Target-specific archives with SHA-256 checksums ship on GitHub releases; the install script pulls the latest alpha.',
  },
  {
    title: 'Release cadence',
    status: 'Planned',
    tone: 'planned',
    body: 'Supported-target policy, recurring release notes, diagnostics examples, and public reports.',
  },
];
---

<BaseLayout
  title="Compiler Releases"
  description="Find the current Ultraviolet compiler release path, source-build instructions, the install script, and public alpha release status."
>
  <article class="ddp-page releases-page">
    <header class="ddp-head">
      <div class="dd-wrap ddp-head-in">
        <p class="ddp-kicker">Compiler downloads</p>
        <h1 class="ddp-h1">Compiler Releases</h1>
        <p class="ddp-lede">
          Install the packaged alpha with one command, download archives
          directly from GitHub releases, or build from source.
        </p>
        <div class="ddp-actions">
          <a class="dd-btn-primary" href="#install">Get the installer</a>
          <a class="dd-btn-ghost" href={releaseStatus.href}>Open GitHub releases</a>
        </div>
      </div>
    </header>

    <ReleaseStatusStrip status={releaseStatus} />

    <div class="dd-wrap">
      <section class="ddp-section" id="install" aria-labelledby="install-heading">
        <div class="ddp-section-head">
          <span class="dd-section-no"><b>01</b> / INSTALL</span>
          <div>
            <h2 class="ddp-h2" id="install-heading">One command.</h2>
            <p class="dd-section-sub">
              The installer downloads the latest packaged alpha from GitHub
              releases, verifies its SHA-256 checksum, and adds the <code>uv</code>
              command to your PATH.
            </p>
          </div>
        </div>
        <div class="ddp-install-block">
          <InstallTabs left />
        </div>
        <p class="ddp-fineprint">
          Already using Python's <code>uv</code>? The installer detects the
          conflict and asks: it can keep the existing tool available as
          <code>pyuv</code>, or install Ultraviolet's CLI as <code>uvc</code>
          instead.
        </p>
        <div class="ddp-linkrow">
          <a href={releaseStatus.href}>Manual downloads on GitHub →</a>
          <a href="/docs/build-the-compiler/">Build from source →</a>
          <a href="/docs/quickstart/">Quickstart: first program →</a>
        </div>
      </section>

      <section class="ddp-section" aria-labelledby="artifacts-heading">
        <div class="ddp-section-head">
          <span class="dd-section-no"><b>02</b> / ARTIFACTS</span>
          <div>
            <h2 class="ddp-h2" id="artifacts-heading">What ships in {releaseStatus.version}.</h2>
            <p class="dd-section-sub">
              Every archive is built in CI and published with its SHA-256
              checksum. The install script verifies before unpacking.
            </p>
          </div>
        </div>
        <div class="ddp-artifact-table" role="table" aria-label="Release artifacts">
          <div class="ddp-artifact-row ddp-artifact-head" role="row">
            <span role="columnheader">Target</span>
            <span role="columnheader">Archive</span>
            <span role="columnheader">Checksum</span>
            <span role="columnheader">CI</span>
          </div>
          {
            releaseStatus.artifacts.map((artifact) => (
              <a class="ddp-artifact-row" href={artifact.href} role="row">
                <span class="target" role="cell">{artifact.target}</span>
                <span class="file" role="cell">{artifact.file}</span>
                <span class="sum" role="cell">{artifact.sum}</span>
                <span class="ok" role="cell">
                  {artifact.verified ? '✓ verified' : 'pending'}
                </span>
              </a>
            ))
          }
        </div>
      </section>

      <section class="ddp-section" aria-labelledby="release-path-heading">
        <div class="ddp-section-head">
          <span class="dd-section-no"><b>03</b> / RELEASE PATH</span>
          <h2 class="ddp-h2" id="release-path-heading">Where release engineering stands.</h2>
        </div>
        <div>
          {
            releaseTimeline.map((item) => (
              <article class="ddp-row ddp-row-three">
                <p class="ddp-row-t">{item.title}</p>
                <p class="ddp-row-d">{item.body}</p>
                <span class="ddp-row-status">
                  <span class={`ddp-tag ${item.tone}`}>{item.status}</span>
                </span>
              </article>
            ))
          }
        </div>
      </section>
      <div class="ddp-bottom-pad"></div>
    </div>
  </article>
</BaseLayout>
