---
import CommandCopy from '../components/CommandCopy.astro';
import BaseLayout from '../layouts/BaseLayout.astro';

const releaseLinks = [
  {
    label: 'Release notes',
    title: 'GitHub releases',
    body: 'Published notes, tags, and artifacts for public compiler drops.',
    href: 'https://github.com/blacklight-foundation/ultraviolet/releases',
    cta: 'Open releases',
  },
  {
    label: 'Build guide',
    title: 'Local compiler build',
    body: 'Prerequisites and bootstrap steps for building the compiler locally.',
    href: '/docs/build-the-compiler/',
    cta: 'Open build guide',
  },
  {
    label: 'First run',
    title: 'Start with the quickstart',
    body: 'Create a manifest, write a first source file, and run the command surface.',
    href: '/docs/quickstart/',
    cta: 'Open quickstart',
  },
];

const releaseTimeline = [
  {
    title: 'Build verification',
    status: 'Now',
    tone: 'now',
    body: 'Build checks, prerequisite validation, and documented verification for local source builds.',
  },
  {
    title: 'Packaged artifacts',
    status: 'Available',
    tone: 'now',
    body: 'Target-specific archives with SHA-256 checksums ship on GitHub releases; the install script pulls the latest alpha.',
  },
  {
    title: 'Release cadence',
    status: 'Planned',
    tone: 'planned',
    body: 'Supported-target policy, recurring release notes, diagnostics examples, and public reports.',
  },
];

const installTargets = [
  {
    platform: 'Linux x86_64 / macOS (Apple Silicon)',
    command: 'curl -fsSL https://ultraviolet-lang.org/install | sh',
  },
  {
    platform: 'Windows x86_64',
    command: 'powershell -c "irm https://ultraviolet-lang.org/install.ps1 | iex"',
  },
];
---

<BaseLayout
  title="Compiler Releases"
  description="Find the current Ultraviolet compiler release path, source-build instructions, the install script, and public alpha release status."
>
  <article class="article-page status-page releases-page">
    <header>
      <p class="eyebrow">Compiler downloads</p>
      <h1>Compiler Releases</h1>
      <p>
        Install the packaged alpha with one command, download archives
        directly from GitHub releases, or build from source.
      </p>
      <div class="actions">
        <a class="button primary" href="#install">
          Get the installer
        </a>
        <a class="button secondary" href="https://github.com/blacklight-foundation/ultraviolet/releases">
          Open GitHub releases
        </a>
      </div>
    </header>

    <section class="card release-current" aria-labelledby="release-status-heading">
      <div>
        <span class="status-kicker">Available now</span>
        <h2 id="release-status-heading">Packaged alpha builds.</h2>
      </div>
      <p>
        Packaged archives with SHA-256 checksums ship for Linux x86_64, macOS
        on Apple Silicon, and Windows x86_64. Building from source remains
        fully supported.
      </p>
      <a class="button secondary" href="/docs/build-the-compiler/">
        Open build guide
      </a>
    </section>

    <section id="install" class="status-page-section" aria-labelledby="install-script-heading">
      <h2 id="install-script-heading">Install script</h2>
      <p>
        The installer downloads the latest packaged alpha from GitHub
        releases, verifies its SHA-256 checksum, and adds the
        <code>uv</code> command to your PATH.
      </p>
      <div class="install-command-list">
        {
          installTargets.map((target) => (
            <div class="install-command-row">
              <span class="install-platform">{target.platform}</span>
              <CommandCopy command={target.command} />
            </div>
          ))
        }
      </div>
      <p class="install-note">
        Already using Python's <code>uv</code>? The installer detects the
        conflict and asks: it can keep the existing tool available as
        <code>pyuv</code>, or install Ultraviolet's CLI as <code>uvc</code>
        instead.
      </p>
    </section>

    <section class="status-page-section">
      <h2>Release paths</h2>
      <div class="status-card-grid">
        {
          releaseLinks.map((link) => (
            <a class="card post-card compact-card status-link-card" href={link.href}>
              <span class="status-tag">{link.label}</span>
              <h3>{link.title}</h3>
              <p>{link.body}</p>
              <span class="card-cta">{link.cta}</span>
            </a>
          ))
        }
      </div>
    </section>

    <section class="status-page-section">
      <h2>Release timeline</h2>
      <div class="timeline">
        {
          releaseTimeline.map((item) => (
            <article class="timeline-item">
              <div>
                <h3>{item.title}</h3>
                <p>{item.body}</p>
              </div>
              <span class={`status-tag status-${item.tone}`}>{item.status}</span>
            </article>
          ))
        }
      </div>
      <p>
        See the <a href="/roadmap/">public alpha roadmap</a> for current work,
        funded milestones, and delivery status.
      </p>
    </section>
  </article>
</BaseLayout>
