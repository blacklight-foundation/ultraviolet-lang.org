---
import BaseLayout from '../layouts/BaseLayout.astro';
import NewsletterSignup from '../components/NewsletterSignup.astro';
import { fundingGoals } from '../data/funding';

const principles = [
  {
    title: 'Canonical source forms',
    body: 'Semantic operations have one accepted source form where possible, so generated output has fewer equivalent spellings to review.',
    cue: 'one accepted form',
  },
  {
    title: 'Explicit authority',
    body: 'External effects require capability values. Capability roots enter through Context rather than ambient globals.',
    cue: 'capability roots',
  },
  {
    title: 'Permission and responsibility',
    body: 'Permissions such as const, unique, and shared are separate from responsibility transfer through move.',
    cue: 'access and transfer',
  },
  {
    title: 'Static checks by default',
    body: 'Dynamic checks, synchronization, dispatch, allocation, copying, unsafe behavior, and foreign boundaries require explicit source opt-in.',
    cue: 'runtime opt-in',
  },
];

const statusItems = [
  {
    label: 'Status',
    value: 'Currently in alpha',
  },
  {
    label: 'Compiler',
    value: 'Bootstrap compiler exists',
  },
  {
    label: 'Build path',
    value: 'Being stabilized',
  },
  {
    label: 'Spec',
    value: 'Public specification exists',
  },
  {
    label: 'Stewardship',
    value: 'Blacklight Foundation',
  },
  {
    label: 'Funding',
    value: 'Subscriptions + milestones',
  },
];

const reviewFlow = [
  'LLM prompt',
  'Ultraviolet source',
  'Human review',
  'Compiler check',
];

const reviewSurface = [
  {
    label: 'authority',
    value: 'Capability roots enter through Context.',
  },
  {
    label: 'access',
    value: 'const, unique, and shared describe permission.',
  },
  {
    label: 'responsibility',
    value: 'move and binding state make transfer visible.',
  },
  {
    label: 'runtime opt-ins',
    value: 'Dynamic checks, synchronization, unsafe behavior, and FFI are explicit.',
  },
];
---

<BaseLayout title="Ultraviolet">
  <section class="hero">
    <div class="hero-grid">
      <div>
        <p class="eyebrow">Blacklight Foundation public alpha</p>
        <h1>Ultraviolet</h1>
        <p class="hero-lede">
          A principled, high-visibility, systems programming language for
          LLM-generated source that remains reviewable by humans.
        </p>
        <p class="hero-copy">
          Ultraviolet is currently in alpha. It is designed for source produced
          by LLMs and reviewed by people: canonical source forms, explicit
          authority, local permission and responsibility, and static checks by
          default. The project is stewarded by Blacklight Foundation.
        </p>
        <div class="actions" aria-label="Primary actions">
          <a class="button primary" href="/docs/">Read the docs</a>
          <a class="button ghost" href="/sponsor/">Support the public alpha</a>
          <a
            class="button secondary"
            href="https://github.com/blacklight-foundation/ultraviolet"
          >
            View on GitHub
          </a>
        </div>
      </div>
      <div class="proof-panel" aria-label="Generated source review surface">
        <div class="proof-panel-head">
          <span>review surface</span>
          <span>language model</span>
        </div>
        <div class="review-surface-list">
          {
            reviewSurface.map((item) => (
              <article>
                <span>{item.label}</span>
                <p>{item.value}</p>
              </article>
            ))
          }
        </div>
      </div>
    </div>
  </section>

  <section class="proof-strip" aria-label="Current project status">
    <div class="proof-strip-inner">
      {
        statusItems.map((item) => (
          <article class="proof-metric">
            <span>{item.label}</span>
            <strong>{item.value}</strong>
          </article>
        ))
      }
    </div>
  </section>

  <section class="page-section problem-section">
    <div class="section-heading">
      <h2>LLM-generated systems code still needs source-level review.</h2>
      <p>
        Reviewers need to see where authority enters, which values move or
        alias, when effects occur, and which behavior depends on runtime checks.
        Ultraviolet puts those review properties in the source language instead
        of treating them as comments, conventions, or generator policy.
      </p>
    </div>
    <div class="review-flow" aria-label="Review loop">
      {
        reviewFlow.map((item) => (
          <div class="review-flow-step">
            <span>{item}</span>
          </div>
        ))
      }
    </div>
  </section>

  <section class="band">
    <div class="page-section compact-section">
      <div class="section-heading">
        <h2>Language model</h2>
      </div>
      <div class="grid four-col">
        {
          principles.map((principle) => (
            <article class="card principle-card">
              <span>{principle.cue}</span>
              <h3>{principle.title}</h3>
              <p>{principle.body}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="page-section">
    <div class="grid two-col funding-summary">
      <div class="section-heading">
        <h2>Support the public alpha.</h2>
        <p>
          Blacklight Foundation funds the public compiler, specification,
          documentation, examples, diagnostics, CI, training material, and
          community infrastructure for Ultraviolet.
        </p>
        <div class="actions">
          <a class="button primary" href="/sponsor/#support-tiers">
            See support options
          </a>
          <a class="button secondary" href="/sponsor/#funding-goals">
            View funding goals
          </a>
        </div>
      </div>
      <div class="funding-rail">
        {
          fundingGoals.map((fund) => (
            <article class="card funding-card">
              <div>
                <h3>{fund.title}</h3>
                <p class="muted">{fund.purpose}</p>
              </div>
              <p class="funding-goal">{fund.goal}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="band">
    <div class="page-section">
      <NewsletterSignup source="home" />
    </div>
  </section>

  <section class="page-section">
    <div class="section-heading">
      <h2>
        Help build a language for reviewable LLM-generated systems source.
      </h2>
      <div class="actions">
        <a class="button primary" href="/sponsor/">Support the public alpha</a>
      </div>
    </div>
  </section>
</BaseLayout>
