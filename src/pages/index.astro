      ['    }'],
      ['}'],
    ],
  },
  {
    title: 'CPU + GPU programming',
    body: 'Write code for CPU or GPU execution in one language model, with execution domains exposed as typed capabilities.',
    href: '/docs/core-language/cpu-gpu-programming/',
    exampleTitle: 'GPU and CPU domains',
    exampleLines: [
      [term('visibility', 'public'), ' ', term('procedure', 'procedure'), ' scanLuma(ctx: Context, pixels: [f32; 1024]) {'],
      ['    ', term('parallel', 'parallel'), ' ', term('contextDomain', 'ctx.gpu'), '() {'],
      ['        ', term('dispatch', 'dispatch'), ' pixel in 0..1024 {'],
      ['            let luma: f32 = pixels[pixel]'],
      ['            classifyPixel(pixel, luma)'],
      ['        }'],
      ['    }'],
      [''],
      ['    ', term('parallel', 'parallel'), ' ', term('contextDomain', 'ctx.cpu'), '() {'],
      ['        ', term('dispatch', 'dispatch'), ' tile in 0..16 {'],
      ['            summarizeTile(tile)'],
      ['        }'],
      ['    }'],
      ['}'],
    ],
  },
  {
    title: 'Abstraction and polymorphism',
    body: 'Classes, generic bounds, and dynamic class objects expose abstraction choices in source.',
    href: '/docs/specification/abstraction-and-polymorphism/',
    exampleTitle: 'Class-bound rendering',
    exampleLines: [
      [term('visibility', 'public'), ' ', term('classDecl', 'class'), ' Renderer {'],
      ['    ', term('visibility', 'public'), ' ', term('procedure', 'procedure'), ' render(', term('receiver', '~'), ', value: ', term('const', 'const'), ' User) -> string@Managed'],
      ['}'],
      [term('visibility', 'public'), ' ', term('record', 'record'), ' JsonRenderer ', term('classBound', '<:'), ' Renderer {'],
      ['    ', term('visibility', 'public'), ' ', term('override', 'override'), ' ', term('procedure', 'procedure'), ' render(', term('receiver', '~'), ', value: ', term('const', 'const'), ' User) -> string@Managed {'],
      ['        return renderJson(value, 2)'],
      ['    }'],
      ['}'],
      [term('visibility', 'public'), ' ', term('procedure', 'procedure'), ' renderStatic', term('generic', '<T <: Renderer>'), '(r: T, value: ', term('const', 'const'), ' User) -> string@Managed {'],
      ['    return r', term('call', '~>'), 'render(value)'],
      ['}'],
      [term('visibility', 'public'), ' ', term('procedure', 'procedure'), ' renderDynamic(renderer: ', term('dynamicType', '$Renderer'), ', value: ', term('const', 'const'), ' User) -> string@Managed {'],
      ['    return renderer', term('call', '~>'), 'render(value)'],
      ['}'],
    ],
  },
  {
    title: 'Compile-time generation',
    body: 'comptime, quote/splice, reflection, and emission support controlled generated source.',
    href: '/docs/specification/compile-time-execution-and-metaprogramming/',
    exampleTitle: 'Checked emission',
    exampleLines: [
      [term('emitAttribute', '[[emit]]')],
      [term('comptime', 'comptime'), ' {'],
      ['    let field_count = introspect', term('call', '~>'), 'fieldCount(Type::<UserRecord>)'],
      ['    let generated = ', term('quote', 'quote'), ' {'],
