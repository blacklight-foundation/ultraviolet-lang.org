---
import BaseLayout from '../layouts/BaseLayout.astro';
import NewsletterSignup from '../components/NewsletterSignup.astro';
import { fundingGoals } from '../data/funding';

const constructExplainers = {
  visibility: {
    title: 'Visibility',
    body: '`public` makes a declaration or member part of the exported surface.',
    href: '/docs/specification/name-resolution-and-visibility/',
  },
  modal: {
    title: 'Modal type',
    body: 'A modal type declares an explicit lifecycle with named, checked states.',
    href: '/docs/modal-programming/',
  },
  state: {
    title: 'Modal state',
    body: 'A concrete state in a modal lifecycle; only valid state operations are available.',
    href: '/docs/modal-programming/',
  },
  procedure: {
    title: 'Procedure',
    body: 'A procedure exposes its parameters, result type, effects, and contracts in its signature.',
    href: '/docs/specification/procedures-and-contracts/',
  },
  receiver: {
    title: 'Receiver shorthand',
    body: '`~` declares the method receiver and introduces `self` inside the method body.',
    href: '/docs/specification/procedures-and-contracts/',
  },
  move: {
    title: 'move',
    body: '`move` makes responsibility transfer explicit instead of hiding ownership changes.',
    href: '/docs/core-language/permissions/',
  },
  shared: {
    title: 'shared permission',
    body: '`shared` marks coordinated shared access through the permission and key systems.',
    href: '/docs/core-language/permissions/',
  },
  unionReturn: {
    title: 'Union return',
    body: 'The return type lists every state the operation can produce.',
    href: '/docs/specification/complete-grammar-reference/',
  },
  contract: {
    title: 'Contract clause',
    body: '`|:` makes the precondition part of the source contract reviewers can inspect.',
    href: '/docs/core-language/contracts/',
  },
  call: {
    title: 'Receiver call',
    body: '`~>` makes receiver-style operations explicit at call sites.',
    href: '/docs/specification/expressions/',
  },
  stateValue: {
    title: 'State value',
    body: 'Constructs or returns a concrete modal state value.',
    href: '/docs/modal-programming/',
  },
  transition: {
    title: 'Transition',
    body: 'A modal transition consumes one concrete state and returns another.',
    href: '/docs/modal-programming/',
  },
  parallel: {
    title: 'parallel',
    body: 'Starts structured parallel work in an explicit execution domain.',
    href: '/docs/specification/structured-parallelism/',
  },
  dispatch: {
    title: 'dispatch',
    body: 'Partitions work items over a range inside a parallel block.',
    href: '/docs/specification/structured-parallelism/',
  },
  domain: {
    title: 'Execution domain',
    body: 'CPU, GPU, and inline execution are explicit source-level domains.',
    href: '/docs/core-language/cpu-gpu-programming/',
  },
  key: {
    title: 'Key clause',
    body: 'Coordinates access to shared paths and makes conflict boundaries reviewable.',
    href: '/docs/core-language/key-system/',
  },
  keyBlock: {
    title: 'Key block',
    body: 'Acquires read or write authority over shared paths for a lexical block.',
    href: '/docs/core-language/key-system/',
  },
  ordered: {
    title: 'ordered',
    body: 'Requests deterministic ordered access for indexed shared paths.',
    href: '/docs/core-language/key-system/',
  },
  race: {
    title: 'race',
    body: 'Waits for the first async result and handles it with an explicit pattern.',
    href: '/docs/specification/asynchronous-operations/',
  },
  sync: {
    title: 'sync',
    body: 'Synchronously waits on an async operation at an explicit source site.',
    href: '/docs/specification/asynchronous-operations/',
  },
  comptime: {
    title: 'comptime',
    body: 'Runs source-level generation during the compile-time execution phase.',
    href: '/docs/specification/compile-time-execution-and-metaprogramming/',
  },
  quote: {
    title: 'quote',
    body: 'Builds a checked AST fragment for controlled compile-time emission.',
    href: '/docs/specification/compile-time-execution-and-metaprogramming/',
  },
  splice: {
    title: 'splice',
    body: 'Injects a compile-time value into a quoted source fragment.',
    href: '/docs/specification/compile-time-execution-and-metaprogramming/',
  },
  context: {
    title: 'Context',
    body: '`Context` carries the runtime capability bundle into executable code.',
    href: '/docs/core-language/explicit-effects/',
  },
  contextField: {
    title: 'Capability field',
    body: 'Runtime capability values are reached through fields on the explicit context value.',
    href: '/docs/core-language/explicit-effects/',
  },
  contextDomain: {
    title: 'Context execution domain',
    body: '`ctx.cpu()`, `ctx.gpu()`, and `ctx.inline()` produce typed execution-domain values.',
    href: '/docs/core-language/cpu-gpu-programming/',
  },
  emitAttribute: {
    title: 'emit attribute',
    body: '`[[emit]]` grants the compile-time emitter capability at that source site.',
    href: '/docs/specification/compile-time-execution-and-metaprogramming/',
  },
  emitter: {
    title: 'TypeEmitter',
    body: '`emitter~>emit` inserts checked AST declarations during compile-time execution.',
    href: '/docs/specification/compile-time-execution-and-metaprogramming/',
  },
} as const;

const term = (key: keyof typeof constructExplainers, text: string) => ({
  key,
  text,
});

const annotatedExamples = [
  {
    title: 'Bounded Webhook Retry',
    lines: [
      [term('visibility', 'public'), ' ', term('modal', 'modal'), ' HookJob {'],
      ['    ', term('state', '@Queued'), ' {'],
      ['        ', term('visibility', 'public'), ' path: string@View'],
      ['        ', term('visibility', 'public'), ' attempt: u8'],
      ['        ', term('visibility', 'public'), ' ', term('procedure', 'procedure'), ' send(', term('receiver', '~'), ', net: ', term('shared', 'shared'), ' Net)'],
      ['          -> HookJob@Sent ', term('unionReturn', '|'), ' HookJob@Retry'],
      ['           ', term('unionReturn', '|'), ' HookJob@Failed'],
      ['          ', term('contract', '|:'), ' self.attempt < 5'],
      ['        {'],
      ['            if (net', term('call', '~>'), 'post(self.path)) { return ', term('stateValue', 'HookJob@Sent'), ' {} }'],
      ['            if (self.attempt == 4) { return ', term('stateValue', 'HookJob@Failed'), ' {} }'],
      ['            return ', term('stateValue', 'HookJob@Retry'), ' { attempt: self.attempt + 1 }'],
      ['        }'],
      ['    }'],
      ['    ', term('state', '@Retry'), ' { ', term('visibility', 'public'), ' attempt: u8 }'],
      ['    ', term('state', '@Sent'), ' {} ', term('state', '@Failed'), ' {}'],
      ['}'],
    ],
  },
  {
    title: 'Parallel Index Rebuild',
    lines: [
      [term('visibility', 'public'), ' ', term('procedure', 'procedure'), ' rebuildIndex('],
      ['    ctx: Context,'],
      ['    docs: ', term('shared', 'shared'), ' DocumentStore,'],
      ['    index: ', term('shared', 'shared'), ' SearchIndex'],
      [') {'],
      ['    ', term('parallel', 'parallel'), ' ctx', term('call', '~>'), 'cpu() {'],
      ['        ', term('dispatch', 'dispatch'), ' shard in docs', term('call', '~>'), 'shards() {'],
      ['            ', term('keyBlock', '#'), ' index[#shard] ', term('ordered', 'ordered'), ' write {'],
      ['                let batch: RowBatch = docs', term('call', '~>'), 'read(shard)'],
      ['                index', term('call', '~>'), 'replace(shard, ', term('move', 'move'), ' batch)'],
      ['            }'],
      ['        }'],
      ['    }'],
      ['}'],
    ],
  },
  {
    title: 'Cache Fallback Race',
    lines: [
      [term('visibility', 'public'), ' ', term('procedure', 'procedure'), ' loadProfile('],
      ['    user_id: UserId,'],
      ['    cache: ', term('shared', 'shared'), ' ProfileCache,'],
      ['    api: ', term('shared', 'shared'), ' ProfileApi'],
      [') -> Profile ', term('unionReturn', '|'), ' ProfileError {'],
      ['    let cached = cache', term('call', '~>'), 'lookupAsync(user_id)'],
      ['    let remote = api', term('call', '~>'), 'fetchAsync(user_id)'],
      ['    return ', term('race', 'race'), ' {'],
      ['        cached -> | hit | hit,'],
      ['        remote -> | fresh | {'],
      ['            ', term('keyBlock', '#'), ' cache write {'],
      ['                cache', term('call', '~>'), 'store(user_id, fresh)'],
      ['            }'],
      ['            fresh'],
      ['        },'],
      ['    }'],
      ['}'],
    ],
  },
  {
    title: 'Payment Commit Gate',
    lines: [
      [term('visibility', 'public'), ' ', term('modal', 'modal'), ' PayTx {'],
      ['    ', term('state', '@Open'), ' {'],
      ['        ', term('visibility', 'public'), ' due: Money'],
      ['        ', term('visibility', 'public'), ' ', term('procedure', 'procedure'), ' settle(', term('receiver', '~'), ', bank: ', term('shared', 'shared'), ' Bank)'],
      ['          -> PayTx@Paid ', term('unionReturn', '|'), ' PayTx@Void'],
      ['          ', term('contract', '|:'), ' self.due', term('call', '~>'), 'isPositive()'],
      ['        {'],
      ['            if (!bank', term('call', '~>'), 'ok(self.due)) { return ', term('stateValue', 'PayTx@Void'), ' {} }'],
      ['            return ', term('stateValue', 'PayTx@Paid'), ' { receipt: bank', term('call', '~>'), 'pay(self.due) }'],
      ['        }'],
      ['    }'],
      ['    ', term('state', '@Paid'), ' { ', term('visibility', 'public'), ' receipt: Receipt }'],
      ['    ', term('state', '@Void'), ' {}'],
      ['}'],
    ],
  },
];

const quickLinks = [
  {
    label: 'Download',
    title: 'Compiler releases',
    body: 'Find public alpha artifacts, source-build status, and release notes.',
    href: '/releases/',
    cta: 'Open releases',
    primary: true,
  },
  {
    label: 'Start',
    title: 'Documentation',
    body: 'Project shape, first program, command surface, and specification links.',
    href: '/docs/',
    cta: 'Read docs',
  },
  {
    label: 'Timeline',
    title: 'Public roadmap',
    body: 'Track build hardening, examples, CI, diagnostics, and release work.',
    href: '/roadmap/',
    cta: 'View roadmap',
  },
  {
    label: 'Support',
    title: 'Support tiers',
    body: 'Fund release engineering, documentation, examples, and infrastructure.',
    href: '/sponsor/#support-tiers',
    cta: 'See tiers',
  },
];

const languageFeatures = [
  {
    title: 'Modal programming',
    body: 'Model resources, protocols, async work, and execution lifecycles as explicit states with checked transitions.',
    cue: 'modal',
    href: '/docs/modal-programming/',
    exampleTitle: 'State-gated session',
    exampleLines: [
      [term('modal', 'modal'), ' Session {'],
      ['    ', term('state', '@Disconnected'), ' {'],
      ['        public ', term('transition', 'transition'), ' connect() -> ', term('state', '@Connected'), ' {'],
      ['            return ', term('stateValue', 'Session@Connected'), ' {}'],
      ['        }'],
      ['    }'],
      ['    ', term('state', '@Connected'), ' {'],
      ['        public ', term('transition', 'transition'), ' close() -> ', term('state', '@Disconnected'), ' {'],
      ['            return ', term('stateValue', 'Session@Disconnected'), ' {}'],
      ['        }'],
      ['    }'],
      ['}'],
    ],
  },
  {
    title: 'Contracts',
    body: 'Preconditions, postconditions, invariants, and foreign contracts make generated assumptions part of source.',
    cue: 'contracts',
    href: '/docs/core-language/contracts/',
    exampleTitle: 'Checked precondition',
    exampleLines: [
      [term('visibility', 'public'), ' ', term('procedure', 'procedure'), ' divide(numerator: i32, denominator: i32) -> i32'],
      [term('contract', '|:'), ' denominator != 0'],
      ['{'],
      ['    return numerator / denominator'],
      ['}'],
    ],
  },
  {
    title: 'Permissions and binding state',
    body: 'move, const, shared, and unique separate transfer of responsibility from access permission.',
    cue: 'access',
    href: '/docs/core-language/permissions/',
    exampleTitle: 'Responsibility plus shared access',
    exampleLines: [
      [term('visibility', 'public'), ' ', term('procedure', 'procedure'), ' flush('],
      ['    ', term('move', 'move'), ' buffer: Buffer,'],
      ['    sink: ', term('shared', 'shared'), ' Sink'],
      [') {'],
      ['    sink', term('call', '~>'), 'write(', term('move', 'move'), ' buffer)'],
      ['}'],
    ],
  },
  {
    title: 'Structured parallelism',
    body: 'parallel, spawn, dispatch, sync, race, and async state share one visible execution model.',
    cue: 'parallel',
    href: '/docs/core-language/structured-concurrency/',
    exampleTitle: 'Structured CPU work',
    exampleLines: [
      [term('parallel', 'parallel'), ' ', term('contextDomain', 'ctx.cpu'), '() {'],
      ['    ', term('dispatch', 'dispatch'), ' item in 0..count {'],
      ['        jobs[item]', term('call', '~>'), 'run()'],
      ['    }'],
      ['}'],
    ],
  },
  {
    title: 'CPU + GPU programming',
    body: 'Write code for CPU or GPU execution in one language model, with execution domains exposed as typed capabilities.',
    cue: 'domains',
    href: '/docs/core-language/cpu-gpu-programming/',
    exampleTitle: 'GPU dispatch domain',
    exampleLines: [
      ['let gpu = ', term('contextDomain', 'ctx.gpu'), '()'],
      [term('parallel', 'parallel'), ' gpu {'],
      ['    ', term('dispatch', 'dispatch'), ' index in 0..count {'],
      ['        output[index] = input[index] * 2'],
      ['    }'],
      ['}'],
    ],
  },
  {
    title: 'Compile-time generation',
    body: 'comptime, quote/splice, reflection, and emission support controlled generated source.',
    cue: 'comptime',
    href: '/docs/specification/compile-time-execution-and-metaprogramming/',
    exampleTitle: 'Checked emission',
    exampleLines: [
      [term('emitAttribute', '[[emit]]')],
      [term('comptime', 'comptime'), ' {'],
      ['    let item = ', term('quote', 'quote'), ' {'],
      ['        ', term('visibility', 'public'), ' ', term('procedure', 'procedure'), ' generated() -> i32 { return 0 }'],
      ['    }'],
      ['    ', term('emitter', 'emitter'), term('call', '~>'), 'emit(item)'],
      ['}'],
    ],
  },
];

---

<BaseLayout title="Ultraviolet">
  <section class="hero">
    <div class="hero-grid">
      <div>
        <p class="eyebrow">Public alpha / Blacklight Foundation</p>
        <h1>Ultraviolet</h1>
        <p class="hero-lede">
          Ultraviolet is a high-visibility, general-purpose systems programming
          language for AI/LLM-generated code and human review.
        </p>
        <p class="hero-copy">
          Designed for performant, safe, and auditable systems. Ultraviolet
          enforces explicit source forms so that LLM-generated assumptions,
          state transitions, and side-effects are visible during review.
        </p>
      </div>
      <div
        class="proof-panel code-proof-panel"
        aria-label="Annotated Ultraviolet source examples"
        data-example-carousel
      >
        <div class="code-panel-head">
          <span data-example-title>{annotatedExamples[0].title}</span>
          <div class="example-controls" aria-label="Example selector">
            {
              annotatedExamples.map((example, index) => (
                <button
                  class={index === 0 ? 'is-active' : ''}
                  type="button"
                  aria-label={`Show ${example.title}`}
                  aria-pressed={index === 0 ? 'true' : 'false'}
                  data-example-control
                  data-example-index={index}
                >
                  {index + 1}
                </button>
              ))
            }
          </div>
        </div>
        <div class="code-panel-stack">
          {
            annotatedExamples.map((example, index) => (
              <article
                class={`code-sample annotated-code-card example-slide${index === 0 ? ' is-active' : ''}`}
                aria-hidden={index === 0 ? 'false' : 'true'}
                data-example-slide
                data-example-title-value={example.title}
              >
                <pre class="annotated-code"><code>{example.lines.map((line) => (
                  <span class="code-line">{line.length === 0 ? '\u00A0' : line.map((part) => {
                    if (typeof part === 'string') return part;
                    const explainer = constructExplainers[part.key];
                    return (
                      <a
                        class="code-term"
                        href={explainer.href}
                        data-title={explainer.title}
                        data-body={explainer.body}
                        aria-label={`${part.text}: ${explainer.title}. ${explainer.body}`}
                      >{part.text}</a>
                    );
                  })}</span>
                ))}</code></pre>
              </article>
            ))
          }
        </div>
        <div class="code-tooltip" data-code-tooltip aria-hidden="true"></div>
      </div>
    </div>
  </section>

  <section class="action-strip" aria-label="Primary project actions">
    <div class="action-strip-inner">
      {
        quickLinks.map((link) => (
          <a class={`action-strip-link${link.primary ? ' is-primary' : ''}`} href={link.href}>
            <span>{link.label}</span>
            <strong>{link.title}</strong>
            <small>{link.body}</small>
            <em>{link.cta}</em>
          </a>
        ))
      }
    </div>
  </section>

  <section class="band">
    <div class="page-section compact-section">
      <div class="section-heading">
        <h2>Language features</h2>
      </div>
      <div class="feature-bento">
        {
          languageFeatures.map((principle) => (
            <article
              class="card principle-card"
              tabindex="0"
              data-feature-card
              aria-label={`${principle.title}: ${principle.body}`}
            >
              <div class="feature-card-summary" data-feature-summary aria-hidden="false">
                <span class="feature-cue">{principle.cue}</span>
                <h3>{principle.title}</h3>
                <p>{principle.body}</p>
              </div>
              <div class="feature-card-reveal" data-feature-reveal aria-hidden="true">
                <div class="feature-example" data-feature-example>
                  <div class="feature-example-head">
                    <span>{principle.exampleTitle}</span>
                  </div>
                  <pre class="annotated-code feature-code"><code>{principle.exampleLines.map((line) => (
                    <span class="code-line">{line.length === 0 ? '\u00A0' : line.map((part) => {
                      if (typeof part === 'string') return part;
                      const explainer = constructExplainers[part.key];
                      return (
                        <a
                          class="code-term"
                          href={explainer.href}
                          data-title={explainer.title}
                          data-body={explainer.body}
                          aria-label={`${part.text}: ${explainer.title}. ${explainer.body}`}
                          tabindex="-1"
                        >{part.text}</a>
                      );
                    })}</span>
                  ))}</code></pre>
                  <div class="code-tooltip" data-code-tooltip aria-hidden="true"></div>
                </div>
                <a class="feature-doc-link" href={principle.href} tabindex="-1">
                  Open docs
                </a>
              </div>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="band">
    <div class="page-section compact-section">
      <NewsletterSignup
        source="home"
        heading="Follow the public alpha"
        description="Compiler progress, language notes, CPU/GPU execution work, funding milestones, and AI-generated-source research updates."
      />
    </div>
  </section>

  <section class="page-section support-summary-section">
    <div class="grid two-col funding-summary">
      <div class="section-heading">
        <h2>Support public alpha work.</h2>
        <p>
          Blacklight Foundation funds compiler and runtime work, examples,
          diagnostics, CI, documentation, CPU/GPU language work, training
          corpus material, and community infrastructure for Ultraviolet.
        </p>
        <div class="actions">
          <a class="button primary" href="/sponsor/#support-tiers">
            See support options
          </a>
          <a class="button secondary" href="/sponsor/#funding-goals">
            View funding goals
          </a>
        </div>
      </div>
      <div class="funding-rail">
        {
          fundingGoals.map((fund) => (
            <article class="card funding-card">
              <div>
                <h3>{fund.title}</h3>
                <p class="muted">{fund.purpose}</p>
              </div>
              <p class="funding-goal">{fund.goal}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <script is:inline>
    (() => {
      const tooltipHiders = [];
      const pointerCanHover = window.matchMedia('(hover: hover)');

      const bindCodeTooltips = (scope) => {
        const tooltip = scope.querySelector('[data-code-tooltip]');
        if (!tooltip) return () => {};

        const hideTooltip = () => {
          tooltip.classList.remove('is-visible');
          tooltip.setAttribute('aria-hidden', 'true');
        };

        const showTooltip = (term) => {
          tooltip.textContent = `${term.dataset.title || ''}\n${term.dataset.body || ''}\nOpen docs`;
          tooltip.classList.add('is-visible');
          tooltip.setAttribute('aria-hidden', 'false');

          const scopeRect = scope.getBoundingClientRect();
          const termRect = term.getBoundingClientRect();
          const tooltipRect = tooltip.getBoundingClientRect();
          const padding = 10;
          const maxLeft = Math.max(padding, scopeRect.width - tooltipRect.width - padding);
          const preferredLeft = termRect.left - scopeRect.left + (termRect.width / 2) - (tooltipRect.width / 2);
          const left = Math.max(padding, Math.min(preferredLeft, maxLeft));
          const preferredTop = termRect.top - scopeRect.top - tooltipRect.height - 8;
          const fallbackTop = termRect.bottom - scopeRect.top + 8;
          const maxTop = Math.max(padding, scopeRect.height - tooltipRect.height - padding);
          const top = preferredTop >= padding
            ? Math.min(preferredTop, maxTop)
            : Math.min(Math.max(fallbackTop, padding), maxTop);

          tooltip.style.left = `${left}px`;
          tooltip.style.top = `${top}px`;
        };

        scope.addEventListener('mouseover', (event) => {
          const term = event.target.closest('.code-term');
          if (term && scope.contains(term)) {
            showTooltip(term);
          }
        });

        scope.addEventListener('mouseout', (event) => {
          const term = event.target.closest('.code-term');
          if (term && !term.contains(event.relatedTarget)) {
            hideTooltip();
          }
        });

        scope.addEventListener('focusin', (event) => {
          const term = event.target.closest('.code-term');
          if (term && scope.contains(term)) {
            showTooltip(term);
          }
        });

        scope.addEventListener('focusout', (event) => {
          const term = event.target.closest('.code-term');
          if (term) {
            hideTooltip();
          }
        });

        scope.querySelectorAll('.annotated-code').forEach((codeBlock) => {
          codeBlock.addEventListener('scroll', hideTooltip);
        });

        tooltipHiders.push(hideTooltip);
        return hideTooltip;
      };

      const hideAllTooltips = () => {
        tooltipHiders.forEach((hideTooltip) => hideTooltip());
      };

      const carousels = document.querySelectorAll('[data-example-carousel]');

      carousels.forEach((carousel) => {
        const slides = Array.from(carousel.querySelectorAll('[data-example-slide]'));
        const controls = Array.from(carousel.querySelectorAll('[data-example-control]'));
        const title = carousel.querySelector('[data-example-title]');
        const hideTooltip = bindCodeTooltips(carousel);
        let activeIndex = 0;
        let timer = null;

        const show = (nextIndex) => {
          hideTooltip();
          activeIndex = (nextIndex + slides.length) % slides.length;

          slides.forEach((slide, index) => {
            const isActive = index === activeIndex;
            slide.classList.toggle('is-active', isActive);
            slide.setAttribute('aria-hidden', isActive ? 'false' : 'true');
            if (isActive && title) {
              title.textContent = slide.dataset.exampleTitleValue || '';
            }
          });

          controls.forEach((control, index) => {
            const isActive = index === activeIndex;
            control.classList.toggle('is-active', isActive);
            control.setAttribute('aria-pressed', isActive ? 'true' : 'false');
          });
        };

        const start = () => {
          if (timer || slides.length < 2) return;
          timer = window.setInterval(() => show(activeIndex + 1), 7000);
        };

        const stop = () => {
          if (!timer) return;
          window.clearInterval(timer);
          timer = null;
        };

        controls.forEach((control) => {
          control.addEventListener('click', () => {
            stop();
            show(Number(control.dataset.exampleIndex || 0));
            start();
          });
        });

        carousel.addEventListener('mouseenter', stop);
        carousel.addEventListener('mouseleave', start);
        carousel.addEventListener('focusin', stop);
        carousel.addEventListener('focusout', start);

        show(0);
        start();
      });

      const featureCards = Array.from(document.querySelectorAll('[data-feature-card]'));

      const setFeatureCard = (card, isRevealed) => {
        const summary = card.querySelector('[data-feature-summary]');
        const reveal = card.querySelector('[data-feature-reveal]');

        card.classList.toggle('is-revealed', isRevealed);
        if (summary) {
          summary.setAttribute('aria-hidden', isRevealed ? 'true' : 'false');
        }
        if (reveal) {
          reveal.setAttribute('aria-hidden', isRevealed ? 'false' : 'true');
          reveal.querySelectorAll('a').forEach((link) => {
            if (isRevealed) {
              link.removeAttribute('tabindex');
            } else {
              link.setAttribute('tabindex', '-1');
            }
          });
        }
      };

      featureCards.forEach((card) => {
        setFeatureCard(card, false);

        card.addEventListener('mouseenter', () => setFeatureCard(card, true));
        card.addEventListener('mouseleave', () => {
          setFeatureCard(card, false);
          hideAllTooltips();
        });

        card.addEventListener('focusin', () => setFeatureCard(card, true));
        card.addEventListener('focusout', (event) => {
          if (!card.contains(event.relatedTarget)) {
            setFeatureCard(card, false);
            hideAllTooltips();
          }
        });

        card.addEventListener('click', (event) => {
          if (event.target.closest('a') || pointerCanHover.matches) return;
          setFeatureCard(card, !card.classList.contains('is-revealed'));
        });

        card.addEventListener('keydown', (event) => {
          if ((event.key === 'Enter' || event.key === ' ') && event.target === card) {
            event.preventDefault();
            setFeatureCard(card, !card.classList.contains('is-revealed'));
          }

          if (event.key === 'Escape') {
            setFeatureCard(card, false);
            hideAllTooltips();
          }
        });
      });

      document.querySelectorAll('[data-feature-example]').forEach((example) => {
        bindCodeTooltips(example);
      });

      document.addEventListener('keydown', (event) => {
        if (event.key === 'Escape') {
          featureCards.forEach((card) => setFeatureCard(card, false));
          hideAllTooltips();
        }
      });

      window.addEventListener('resize', hideAllTooltips);
      window.addEventListener('scroll', hideAllTooltips, { passive: true });
    })();
  </script>
</BaseLayout>
