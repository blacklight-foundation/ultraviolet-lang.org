      ['        }'],
      ['    }'],
      [''],
      ['    ', term('emitter', 'emitter'), term('call', '~>'), 'emit(generated)'],
      ['}'],
    ],
  },
  {
    title: 'Foreign function interface',
    body: 'extern blocks, C layout, unsafe calls, and FFI attributes make foreign boundaries inspectable.',
    href: '/docs/specification/foreign-function-interface/',
    exampleTitle: 'C ABI boundary',
    exampleLines: [
      [term('layoutAttribute', '[[layout(C)]]')],
      [term('visibility', 'public'), ' ', term('record', 'record'), ' NativePoint {'],
      ['    ', term('visibility', 'public'), ' x: f32'],
      ['    ', term('visibility', 'public'), ' y: f32'],
      ['}'],
      [term('libraryAttribute', '[[library(name: "uvmath", kind: "static")]]')],
      [term('visibility', 'public'), ' ', term('extern', 'extern'), ' "C" {'],
      ['    ', term('mangleAttribute', '[[mangle("uv_distance")]]')],
      ['    ', term('visibility', 'public'), ' ', term('procedure', 'procedure'), ' native_distance(a: NativePoint, b: NativePoint) -> f32'],
      ['}'],
      [term('visibility', 'public'), ' ', term('procedure', 'procedure'), ' distanceFromOrigin(point: NativePoint) -> f32 {'],
      ['    let origin = NativePoint { x: 0.0, y: 0.0 }'],
      ['    ', term('unsafe', 'unsafe'), ' { return native_distance(point, origin) }'],
