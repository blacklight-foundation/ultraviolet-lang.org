      [''],
      ['    ', term('region', 'region'), ' as scratch {'],
      ['        let header = scratch ', term('regionAlloc', '^'), ' Header { count: source', term('call', '~>'), 'length() }'],
      [''],
      ['        scratch.', term('frame', 'frame'), ' {'],
      ['            let row = scratch ', term('regionAlloc', '^'), ' RowScratch { index: 0, width: header.count }'],
      ['            summary.rows = scanRows(source, row)'],
      ['        }'],
      [''],
      ['        scratch.', term('frame', 'frame'), ' {'],
      ['            let table = scratch ', term('regionAlloc', '^'), ' IndexScratch { slots: summary.rows }'],
      ['            summary.checksum = foldChecksum(table)'],
      ['        }'],
