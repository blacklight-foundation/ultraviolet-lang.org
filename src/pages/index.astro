    href: '/docs/specification/statements-and-blocks/',
    exampleTitle: 'Scratch decoding arena',
    exampleLines: [
      [term('visibility', 'public'), ' ', term('procedure', 'procedure'), ' decodeBatch(source: bytes@View) -> BatchSummary {'],
